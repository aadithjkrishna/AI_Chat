{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run FastAPI Dev Server",
            "type": "shell",
            "command": "./.venv/bin/fastapi dev main.py", 
            "options": {
               
                "cwd": "${workspaceFolder}/backend"
            },
            "group": {
                "kind": "solid",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": []
        }
    ]
    }
